{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Usage (Pods)",
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"apps\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ],
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage (Pods)",
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{namespace=\"apps\"}) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ],
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    },
    {
      "type": "stat",
      "title": "Running Pods",
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"apps\", phase=\"Running\"})"
        }
      ],
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 16 }
    },
    {
      "type": "stat",
      "title": "Total Pods",
      "targets": [
        {
          "expr": "count(kube_pod_info{namespace=\"apps\"})"
        }
      ],
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 16 }
    }
  ],
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["kubernetes", "apps"],
  "title": "Apps Namespace Monitoring",
  "version": 1
}